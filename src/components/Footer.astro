---
// Footer Component — premium redesign
import logo from '../assets/logo.png';
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-[#0a0306] dark:bg-[#0a0306] overflow-hidden" role="contentinfo">

  <!-- Decorative blobs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/4 w-[600px] h-[300px] rounded-full bg-[#701D2A]/15 blur-[80px]"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] rounded-full bg-[#FF6B35]/8 blur-[80px]"></div>
  </div>

  <!-- Top gradient border -->
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-[#FF6B35] to-transparent" aria-hidden="true"></div>

  <!-- Main content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12 mb-12">

      <!-- Brand column -->
      <div class="space-y-5 lg:col-span-1">
        <a href="/" aria-label="Walter Entrenamiento — Inicio" class="inline-block group">
          <div class="w-16 h-16 rounded-2xl overflow-hidden transition-all duration-300 group-hover:scale-105 group-hover:shadow-[0_4px_16px_rgba(255,107,53,0.35)]">
            <img
              src={logo.src}
              alt="Walter Entrenamiento"
              class="w-full h-full object-contain"
              width="64"
              height="64"
              loading="lazy"
            />
          </div>
        </a>
        <p class="font-quicksand text-gray-400 text-sm leading-relaxed max-w-xs">
          Más de 30 años transformando vidas a través del movimiento, la disciplina y el bienestar integral en Buenos Aires.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-3" role="list" aria-label="Redes sociales">
          <!-- Instagram -->
          <a
            href="https://instagram.com/walter.entrenamiento"
            target="_blank"
            rel="noopener noreferrer"
            class="group/social w-10 h-10 rounded-xl bg-white/5 border border-white/8 hover:bg-gradient-to-br hover:from-[#E1306C] hover:to-[#833AB4] hover:border-transparent flex items-center justify-center transition-all duration-300 hover:scale-110 hover:shadow-[0_4px_16px_rgba(225,48,108,0.40)]"
            aria-label="Seguir en Instagram"
            role="listitem"
          >
            <svg class="w-4.5 h-4.5 text-gray-400 group-hover/social:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/5491168271296"
            target="_blank"
            rel="noopener noreferrer"
            class="group/social w-10 h-10 rounded-xl bg-white/5 border border-white/8 hover:bg-gradient-to-br hover:from-[#25D366] hover:to-[#128C7E] hover:border-transparent flex items-center justify-center transition-all duration-300 hover:scale-110 hover:shadow-[0_4px_16px_rgba(37,211,102,0.40)]"
            aria-label="Contactar por WhatsApp"
            role="listitem"
          >
            <svg class="w-4.5 h-4.5 text-gray-400 group-hover/social:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <nav aria-label="Navegación del sitio">
        <h3 class="font-montserrat text-sm font-black text-white uppercase tracking-widest mb-5 flex items-center gap-2">
          <span class="w-4 h-[2px] bg-[#FF6B35] rounded-full" aria-hidden="true"></span>
          Páginas
        </h3>
        <ul class="space-y-2.5">
          {[
            { href: '/', label: 'Inicio' },
            { href: '/sobre-walter', label: 'Sobre Walter' },
            { href: '/servicios', label: 'Servicios' },
            { href: '/bienestar', label: 'Bienestar' },
            { href: '/galeria', label: 'Galería' },
            { href: '/#contacto', label: 'Contacto' },
          ].map(link => (
            <li>
              <a
                href={link.href}
                class="group/link font-quicksand text-gray-400 hover:text-[#FF6B35] text-sm transition-all duration-300 flex items-center gap-2"
              >
                <span class="w-0 h-[1.5px] bg-[#FF6B35] rounded-full transition-all duration-300 group-hover/link:w-3 shrink-0" aria-hidden="true"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Services -->
      <nav aria-label="Servicios ofrecidos">
        <h3 class="font-montserrat text-sm font-black text-white uppercase tracking-widest mb-5 flex items-center gap-2">
          <span class="w-4 h-[2px] bg-[#FF6B35] rounded-full" aria-hidden="true"></span>
          Servicios
        </h3>
        <ul class="space-y-2.5">
          {[
            { href: '/servicios#entrenamientos', label: 'Entrenamientos Personalizados' },
            { href: '/servicios#grupales', label: 'Entrenamientos Grupales' },
            { href: '/servicios#terapeutico', label: 'Acompañamiento Terapéutico' },
            { href: '/servicios#masajes', label: 'Masajes Especializados' },
            { href: '/servicios#rehabilitacion', label: 'Rehabilitación' },
            { href: '/servicios#terapias', label: 'Terapias Complementarias' },
          ].map(link => (
            <li>
              <a
                href={link.href}
                class="group/link font-quicksand text-gray-400 hover:text-[#FF6B35] text-sm transition-all duration-300 flex items-center gap-2"
              >
                <span class="w-0 h-[1.5px] bg-[#FF6B35] rounded-full transition-all duration-300 group-hover/link:w-3 shrink-0" aria-hidden="true"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact Info -->
      <address class="not-italic space-y-4">
        <h3 class="font-montserrat text-sm font-black text-white uppercase tracking-widest mb-5 flex items-center gap-2">
          <span class="w-4 h-[2px] bg-[#FF6B35] rounded-full" aria-hidden="true"></span>
          Contacto
        </h3>

        <!-- Phone/WA -->
        <a href="https://wa.me/5491168271296" target="_blank" rel="noopener noreferrer" class="group/contact flex items-start gap-3 hover:text-[#FF6B35] transition-colors duration-300">
          <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/8 flex items-center justify-center shrink-0 mt-0.5 group-hover/contact:bg-[#FF6B35]/15 group-hover/contact:border-[#FF6B35]/25 transition-all duration-300">
            <svg class="w-4 h-4 text-[#FF6B35]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <span class="font-quicksand text-gray-400 group-hover/contact:text-[#FF6B35] text-sm transition-colors duration-300 pt-1">+54 9 11 6827-1296</span>
        </a>

        <!-- Location -->
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/8 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[#FF6B35]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <span class="font-quicksand text-gray-400 text-sm pt-1">Almagro, Buenos Aires<br/>Argentina</span>
        </div>

        <!-- Hours -->
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/8 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[#FF6B35]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="font-quicksand text-gray-400 text-sm pt-1">Lun–Vie: 7:00–21:00<br/>Sáb: 8:00–14:00</span>
        </div>
      </address>
    </div>

    <!-- Divider -->
    <div class="border-t border-white/6 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="font-quicksand text-gray-600 text-sm">
          © {currentYear} Walter Entrenamiento. Todos los derechos reservados.
        </p>
        <div class="flex items-center gap-6">
          <a href="/politica-privacidad" class="font-quicksand text-gray-600 hover:text-[#FF6B35] text-sm transition-colors duration-300">
            Política de Privacidad
          </a>
          <a href="/terminos" class="font-quicksand text-gray-600 hover:text-[#FF6B35] text-sm transition-colors duration-300">
            Términos y Condiciones
          </a>
          <p class="font-quicksand text-gray-600 text-sm">
            Diseñado por <a href="https://www.josecarrizo-dev.com" target="_blank" rel="noopener noreferrer" class="text-[#FF6B35]/80 hover:text-[#FF6B35] transition-colors duration-300 font-semibold">José Carrizo</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
