---
import Layout from '../layouts/Layout.astro';
import PrimaryButton from '../components/ux/PrimaryButton.astro';
---

<Layout
  title="Contacto | Walter Entrenamiento"
  description="Contactá a Walter Entrenamiento por WhatsApp, email o Instagram. Entrenador personal en Barrio Almagro, Buenos Aires."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative pt-32 pb-0 bg-white dark:bg-[#0f0508] overflow-hidden">
    <!-- Decorative blobs -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#FF6B35]/7 dark:bg-[#FF6B35]/10 blur-[100px]"></div>
      <div class="absolute top-1/2 -left-24 w-[400px] h-[400px] rounded-full bg-[#701D2A]/6 dark:bg-[#701D2A]/15 blur-[80px]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pb-24">
      <div class="text-center space-y-6 max-w-3xl mx-auto">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 bg-[#FF6B35]/10 dark:bg-[#FF6B35]/15 border border-[#FF6B35]/20 px-4 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF6B35] animate-pulse-glow" aria-hidden="true"></span>
          <span class="font-montserrat text-xs font-bold text-[#C83B08] dark:text-[#FF6B35] uppercase tracking-widest">Hablemos</span>
        </div>

        <h1 class="font-montserrat text-5xl lg:text-7xl font-black leading-[0.95] text-gray-900 dark:text-white">
          Con<span class="bg-gradient-to-r from-[#FF6B35] via-[#C83B08] to-[#701D2A] bg-clip-text text-transparent">tacto</span>
        </h1>
        <p class="font-quicksand text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
          Elegí tu canal preferido y empezá tu transformación hoy.
        </p>
      </div>
    </div>

    <!-- Wave divider — matches next section bg -->
    <div class="relative" aria-hidden="true">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16 lg:h-20">
        <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" class="fill-gray-50 dark:fill-[#130308]"/>
      </svg>
    </div>
  </section>

  <!-- ============================================================
       CONTACT GRID
       ============================================================ -->
  <section class="py-24 bg-gray-50 dark:bg-[#130308]" aria-labelledby="contact-grid-heading">
    <!-- Visually hidden heading for screen readers — the hero h1 covers the page topic -->
    <h2 id="contact-grid-heading" class="sr-only">Canales de contacto</h2>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-6 lg:gap-8 items-start">

        <!-- Column 1: Primary contact channels -->
        <div class="space-y-4">

          <!-- WhatsApp — primary CTA card -->
          <a
            href="https://wa.me/5491168271296?text=Hola,%20me%20gustaría%20obtener%20más%20información"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 bg-gradient-to-br from-[#0f1f14] to-[#0a1a10] border border-[#25D366]/20 hover:border-[#25D366]/50 rounded-2xl p-6 transition-all duration-400 hover:shadow-[0_8px_32px_rgba(37,211,102,0.2)] hover:-translate-y-0.5"
            aria-label="Contactar por WhatsApp — +54 9 11 6827-1296"
          >
            <div class="shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-[#25D366] to-[#128C7E] flex items-center justify-center group-hover:scale-110 group-hover:shadow-[0_4px_16px_rgba(37,211,102,0.45)] transition-all duration-300">
              <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-montserrat font-bold text-white text-base mb-0.5 group-hover:text-[#25D366] transition-colors duration-300">WhatsApp</p>
              <p class="font-quicksand text-gray-400 text-sm mb-1.5">Escribinos directamente — respuesta rápida</p>
              <p class="font-montserrat font-bold text-[#25D366] text-sm">+54 9 11 6827-1296</p>
            </div>
            <svg class="w-5 h-5 text-gray-600 group-hover:text-[#25D366] group-hover:translate-x-1 transition-all duration-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <!-- Email card -->
          <a
            href="mailto:waltertrainerhoffman@gmail.com"
            class="group flex items-center gap-5 bg-white dark:bg-[#1a0509] border border-gray-100 dark:border-white/5 hover:border-[#FF6B35]/30 dark:hover:border-[#FF6B35]/25 rounded-2xl p-6 transition-all duration-400 hover:shadow-[0_8px_32px_rgba(255,107,53,0.12)] hover:-translate-y-0.5"
            aria-label="Enviar email a waltertrainerhoffman@gmail.com"
          >
            <div class="shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-[#FF6B35]/12 to-[#C83B08]/8 dark:from-[#FF6B35]/20 dark:to-[#C83B08]/12 border border-[#FF6B35]/20 flex items-center justify-center group-hover:scale-110 group-hover:bg-gradient-to-br group-hover:from-[#FF6B35] group-hover:to-[#C83B08] group-hover:border-transparent group-hover:shadow-[0_4px_16px_rgba(255,107,53,0.40)] transition-all duration-300">
              <svg class="w-7 h-7 text-[#FF6B35] group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-montserrat font-bold text-gray-900 dark:text-white text-base mb-0.5 group-hover:text-[#FF6B35] transition-colors duration-300">Email</p>
              <p class="font-quicksand text-gray-500 dark:text-gray-400 text-sm mb-1.5">Envianos un correo electrónico</p>
              <p class="font-montserrat font-bold text-[#FF6B35] text-sm truncate">waltertrainerhoffman@gmail.com</p>
            </div>
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-[#FF6B35] group-hover:translate-x-1 transition-all duration-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>

          <!-- Instagram card -->
          <a
            href="https://instagram.com/walter.entrenamiento"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 bg-white dark:bg-[#1a0509] border border-gray-100 dark:border-white/5 hover:border-[#E1306C]/30 dark:hover:border-[#E1306C]/25 rounded-2xl p-6 transition-all duration-400 hover:shadow-[0_8px_32px_rgba(225,48,108,0.12)] hover:-translate-y-0.5"
            aria-label="Seguir en Instagram @walter.entrenamiento"
          >
            <div class="shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-[#E1306C]/10 to-[#833AB4]/8 dark:from-[#E1306C]/20 dark:to-[#833AB4]/12 border border-[#E1306C]/15 flex items-center justify-center group-hover:scale-110 group-hover:bg-gradient-to-br group-hover:from-[#E1306C] group-hover:via-[#C13584] group-hover:to-[#833AB4] group-hover:border-transparent group-hover:shadow-[0_4px_16px_rgba(225,48,108,0.40)] transition-all duration-300">
              <svg class="w-7 h-7 text-[#E1306C] group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-montserrat font-bold text-gray-900 dark:text-white text-base mb-0.5 group-hover:text-[#E1306C] transition-colors duration-300">Instagram</p>
              <p class="font-quicksand text-gray-500 dark:text-gray-400 text-sm mb-1.5">Seguinos en redes sociales</p>
              <p class="font-montserrat font-bold text-[#E1306C] text-sm">@walter.entrenamiento</p>
            </div>
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-[#E1306C] group-hover:translate-x-1 transition-all duration-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Column 2: Info cards -->
        <div class="space-y-4">

          <!-- Location card -->
          <div class="flex items-center gap-5 bg-white dark:bg-[#1a0509] border border-gray-100 dark:border-white/5 rounded-2xl p-6 shadow-[0_1px_3px_rgba(0,0,0,0.05)]">
            <div class="shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-[#FF6B35]/12 to-[#701D2A]/8 dark:from-[#FF6B35]/20 dark:to-[#701D2A]/15 border border-[#FF6B35]/15 flex items-center justify-center">
              <svg class="w-7 h-7 text-[#FF6B35]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-montserrat font-bold text-gray-900 dark:text-white text-base mb-1">Ubicación</p>
              <p class="font-quicksand text-gray-500 dark:text-gray-400 text-sm">Barrio de Almagro</p>
              <p class="font-montserrat font-bold text-[#FF6B35] text-sm mt-1">Buenos Aires, Argentina</p>
            </div>
          </div>

          <!-- Business hours card — rich dark gradient -->
          <div class="relative overflow-hidden rounded-2xl">
            <div class="absolute inset-0 bg-gradient-to-br from-[#701D2A] to-[#3A0C13]" aria-hidden="true"></div>
            <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 20px 20px;" aria-hidden="true"></div>
            <div class="absolute top-0 right-0 w-32 h-32 rounded-full bg-[#FF6B35]/15 blur-[40px] pointer-events-none" aria-hidden="true"></div>

            <div class="relative z-10 p-6">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-[#FF6B35]/20 border border-[#FF6B35]/25 flex items-center justify-center">
                  <svg class="w-5 h-5 text-[#FF6B35]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <h3 class="font-montserrat font-bold text-white text-lg">Horarios de Atención</h3>
              </div>

              <dl class="space-y-3">
                <div class="flex justify-between items-center py-2.5 border-b border-white/10">
                  <dt class="font-quicksand text-white/75 text-sm">Lunes a Viernes</dt>
                  <dd class="font-montserrat font-bold text-white text-sm">7:00 — 21:00</dd>
                </div>
                <div class="flex justify-between items-center py-2.5 border-b border-white/10">
                  <dt class="font-quicksand text-white/75 text-sm">Sábados</dt>
                  <dd class="font-montserrat font-bold text-white text-sm">8:00 — 14:00</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                  <dt class="font-quicksand text-white/75 text-sm">Domingos</dt>
                  <dd class="font-montserrat font-bold text-white/50 text-sm">Cerrado</dd>
                </div>
              </dl>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       MAP SECTION
       ============================================================ -->
  <section class="py-24 bg-white dark:bg-[#0f0508]" aria-labelledby="map-heading">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-[#FF6B35]/10 dark:bg-[#FF6B35]/15 border border-[#FF6B35]/20 px-4 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF6B35]" aria-hidden="true"></span>
          <span class="font-montserrat text-xs font-bold text-[#C83B08] dark:text-[#FF6B35] uppercase tracking-widest">Ubicación</span>
        </div>
        <h2 id="map-heading" class="font-montserrat text-4xl lg:text-5xl font-black text-gray-900 dark:text-white leading-tight">
          ¿Dónde <span class="bg-gradient-to-r from-[#FF6B35] to-[#C83B08] bg-clip-text text-transparent">entrenamos?</span>
        </h2>
        <p class="font-quicksand text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mt-4">
          Nos encontramos en el Barrio de Almagro, Buenos Aires. Fácil acceso en transporte público.
        </p>
      </div>

      <!-- Map embed -->
      <div class="relative rounded-3xl overflow-hidden shadow-[0_8px_48px_rgba(0,0,0,0.12)] dark:shadow-[0_8px_48px_rgba(0,0,0,0.5)] border border-gray-100 dark:border-white/5">
        <!-- Gradient overlay band at top for brand integration -->
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#FF6B35] via-[#C83B08] to-[#701D2A] z-10" aria-hidden="true"></div>
        <iframe
          title="Mapa de Almagro, Buenos Aires — Walter Entrenamiento"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-58.4378,-34.6205,-58.3978,-34.6005&layer=mapnik&marker=-34.6105,-58.4178"
          width="100%"
          height="480"
          loading="lazy"
          style="border: none; display: block;"
          aria-label="Mapa interactivo mostrando la ubicación en Barrio Almagro, Buenos Aires"
        ></iframe>
      </div>

      <!-- Map caption -->
      <p class="font-quicksand text-sm text-gray-500 dark:text-gray-500 text-center mt-4">
        Mapa: <a href="https://www.openstreetmap.org/#map=15/-34.6105/-58.4178" target="_blank" rel="noopener noreferrer" class="underline hover:text-[#FF6B35] transition-colors duration-200">OpenStreetMap</a> — CC BY-SA 2.0
      </p>

    </div>
  </section>

  <!-- ============================================================
       FINAL CTA BANNER
       ============================================================ -->
  <section class="relative py-24 bg-gray-50 dark:bg-[#130308] overflow-hidden">
    <div class="max-w-4xl mx-auto px-6">
      <div class="relative overflow-hidden rounded-3xl">
        <!-- Animated gradient background -->
        <div class="absolute inset-0 bg-gradient-to-r from-[#FF6B35] via-[#C83B08] to-[#701D2A] animate-gradient-shift" aria-hidden="true"></div>
        <!-- Dot grid texture -->
        <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>

        <div class="relative z-10 px-8 py-14 lg:px-16 lg:py-16 flex flex-col lg:flex-row items-center justify-between gap-8">
          <div class="text-center lg:text-left">
            <h2 class="font-montserrat text-2xl lg:text-3xl font-black text-white mb-2">
              ¿Listo para dar el primer paso?
            </h2>
            <p class="font-quicksand text-white/80 text-base lg:text-lg">
              Agendá tu clase de prueba gratuita hoy mismo.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 shrink-0">
            <PrimaryButton
              href="https://wa.me/5491168271296?text=Hola,%20me%20gustaría%20agendar%20una%20clase%20de%20prueba%20gratuita"
              text="Clase Gratis por WhatsApp"
              icon="whatsapp"
              variant="whatsapp"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <PrimaryButton
              href="https://instagram.com/walter.entrenamiento"
              text="Seguir en Instagram"
              icon="instagram"
              variant="secondary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
              class="border-white/80 text-white hover:bg-white hover:text-[#701D2A] hover:border-white dark:border-white/80 dark:text-white"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
