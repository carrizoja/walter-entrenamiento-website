---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PrimaryButton from '../components/ux/PrimaryButton.astro';
import { getGalleryItems, getFeaturedVideos } from '../lib/queries';

let galleryItems: Awaited<ReturnType<typeof getGalleryItems>> = [];
let featuredVideos: Awaited<ReturnType<typeof getFeaturedVideos>> = [];

try {
  [galleryItems, featuredVideos] = await Promise.all([
    getGalleryItems(),
    getFeaturedVideos(),
  ]);
} catch (err) {
  // Log only — page renders empty state instead of 500.
  console.error('[galeria] Firebase fetch failed:', err);
}

const categories = ['Todos', 'Entrenamientos', 'Grupales', 'Ejercicios', 'Masajes', 'Recuperación', 'Instalaciones'];

const catColors: Record<string, string> = {
  Entrenamientos: '#FF6B35',
  Grupales: '#8C2A3B',
  Ejercicios: '#C56C7A',
  Masajes: '#701D2A',
  Recuperación: '#C83B08',
  Instalaciones: '#3A0C13',
};
---

<Layout>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative pt-32 pb-0 bg-white dark:bg-[#0f0508] overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-[#FF6B35]/7 dark:bg-[#FF6B35]/10 blur-[100px]"></div>
      <div class="absolute bottom-0 -left-24 w-[400px] h-[400px] rounded-full bg-[#701D2A]/6 dark:bg-[#701D2A]/15 blur-[80px]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pb-24">
      <div class="text-center space-y-6 max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-[#FF6B35]/10 dark:bg-[#FF6B35]/15 border border-[#FF6B35]/20 px-4 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF6B35] animate-pulse-glow" aria-hidden="true"></span>
          <span class="font-montserrat text-xs font-bold text-[#C83B08] dark:text-[#FF6B35] uppercase tracking-widest">Momentos en fotos</span>
        </div>
        <h1 class="font-montserrat text-5xl lg:text-7xl font-black leading-[0.95] text-gray-900 dark:text-white">
          <span class="bg-gradient-to-r from-[#FF6B35] via-[#C83B08] to-[#701D2A] bg-clip-text text-transparent">Galería</span> de Momentos
        </h1>
        <p class="font-quicksand text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
          Descubrí nuestras sesiones de entrenamiento, ejercicios y momentos de transformación.
        </p>
      </div>
    </div>

    <div aria-hidden="true">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16 lg:h-20">
        <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" class="fill-gray-50 dark:fill-[#130308]"/>
      </svg>
    </div>
  </section>

  <!-- ============================================================
       STATS BAR
       ============================================================ -->
  <section class="py-10 bg-gray-50 dark:bg-[#130308] border-b border-gray-100 dark:border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { value: galleryItems.filter(i => i.media_type === 'photo').length.toString(), label: 'Fotos', color: '#FF6B35' },
          { value: galleryItems.filter(i => i.media_type === 'video').length.toString(), label: 'Videos', color: '#701D2A' },
          { value: '30+', label: 'Años de Experiencia', color: '#C56C7A' },
          { value: '100+', label: 'Clientes Felices', color: '#C83B08' },
        ].map(stat => (
          <div class="text-center group">
            <div class="font-montserrat text-4xl font-black mb-1 transition-transform duration-300 group-hover:scale-110" style={`color: ${stat.color}`}>
              {stat.value}
            </div>
            <div class="font-quicksand text-sm font-semibold text-gray-500 dark:text-gray-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FILTER TABS (sticky)
       ============================================================ -->
  <section class="py-6 bg-white dark:bg-[#0f0508] sticky top-20 z-40 border-b border-gray-100 dark:border-white/5 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-2.5" role="group" aria-label="Filtrar galería por categoría">
        {categories.map((cat, i) => (
          <button
            class={`filter-btn px-5 py-2 rounded-full font-montserrat font-bold text-sm transition-all duration-300 hover:scale-105 border ${
              i === 0
                ? 'bg-gradient-to-r from-[#FF6B35] to-[#C83B08] text-white border-transparent shadow-[0_2px_12px_rgba(255,107,53,0.30)] active'
                : 'bg-white dark:bg-[#1a0509] text-gray-700 dark:text-gray-300 border-gray-200 dark:border-white/8 hover:border-[#FF6B35]/40 hover:text-[#FF6B35]'
            }`}
            data-filter={cat.toLowerCase()}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       GALLERY GRID
       ============================================================ -->
  <section class="py-16 bg-gray-50 dark:bg-[#130308]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div id="gallery-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {galleryItems.map(item => (
          <div
            data-category={item.category.toLowerCase()}
            class="gallery-item group relative bg-white dark:bg-[#1a0509] rounded-2xl overflow-hidden border border-gray-100 dark:border-white/5 hover:border-[#FF6B35]/25 transition-all duration-400 hover:shadow-[0_12px_40px_rgba(255,107,53,0.12)] hover:-translate-y-1 cursor-pointer"
          >
            <!-- Media area -->
            <div class="relative aspect-square overflow-hidden">
              {item.media_type === 'photo' ? (
                <img
                  src={item.public_url}
                  alt={item.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-[#701D2A] to-[#3A0C13] flex items-center justify-center">
                  {item.thumbnail_url ? (
                    <img src={item.thumbnail_url} alt={item.title} class="w-full h-full object-cover opacity-70" loading="lazy" />
                  ) : null}
                  <!-- Play button -->
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-16 h-16 rounded-full bg-white/15 backdrop-blur-sm border border-white/25 flex items-center justify-center group-hover:scale-110 group-hover:bg-[#FF6B35]/80 transition-all duration-300">
                      <svg class="w-8 h-8 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </div>
              )}

              <!-- Type badge -->
              <div class={`absolute top-3 right-3 px-2.5 py-1 rounded-full font-montserrat text-xs font-bold text-white ${
                item.media_type === 'video'
                  ? 'bg-[#701D2A]/90 backdrop-blur-sm'
                  : 'bg-white/20 backdrop-blur-sm'
              }`}>
                {item.media_type === 'video' ? '▶ Video' : 'Foto'}
              </div>

              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-end pointer-events-none">
                <div class="p-5 w-full">
                  <h3 class="font-montserrat text-base font-black text-white mb-1 leading-snug">{item.title}</h3>
                  <p class="font-quicksand text-white/75 text-xs">{item.description}</p>
                </div>
              </div>
            </div>

            <!-- Info bar -->
            <div class="px-4 py-3 flex items-center justify-between">
              <span
                class="inline-block px-2.5 py-0.5 rounded-full font-montserrat text-xs font-bold text-white"
                style={`background: ${catColors[item.category] || '#701D2A'}`}
              >
                {item.category}
              </span>
              <button
                class="w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-[#FF6B35] hover:bg-[#FF6B35]/10 transition-all duration-300"
                aria-label={`Ver ${item.title}`}
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-20">
        <div class="w-20 h-20 mx-auto rounded-2xl bg-gray-100 dark:bg-[#1a0509] flex items-center justify-center mb-5">
          <svg class="w-10 h-10 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <h3 class="font-montserrat text-xl font-black text-gray-600 dark:text-gray-400 mb-2">Sin resultados</h3>
        <p class="font-quicksand text-gray-500 dark:text-gray-500">Probá con otra categoría</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VIDEO HIGHLIGHTS
       ============================================================ -->
  <section class="py-24 bg-white dark:bg-[#0f0508]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="font-montserrat text-4xl lg:text-5xl font-black text-gray-900 dark:text-white leading-tight">
          Videos <span class="bg-gradient-to-r from-[#FF6B35] to-[#C83B08] bg-clip-text text-transparent">Destacados</span>
        </h2>
        <p class="font-quicksand text-lg text-gray-600 dark:text-gray-400 mt-4 max-w-2xl mx-auto">
          Mirá nuestras rutinas de ejercicios y técnicas de entrenamiento.
        </p>
      </div>

      {featuredVideos.length === 0 ? (
        <p class="text-center font-quicksand text-gray-500 dark:text-gray-400">No hay videos destacados todavía.</p>
      ) : (
        <div class="grid md:grid-cols-2 gap-8">
          {featuredVideos.map(video => (
            <div class="group relative bg-gray-50 dark:bg-[#1a0509] rounded-2xl overflow-hidden border border-gray-100 dark:border-white/5 hover:border-[#FF6B35]/20 transition-all duration-400 hover:shadow-[0_12px_40px_rgba(255,107,53,0.10)]">
              <!-- Thumbnail -->
              <div class="relative aspect-video bg-gradient-to-br from-[#701D2A] to-[#3A0C13] overflow-hidden cursor-pointer">
                {video.thumbnail_url ? (
                  <img src={video.thumbnail_url} alt={video.title} class="w-full h-full object-cover opacity-70" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-24 h-24 text-white/10" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                  </div>
                )}
                <!-- Play button -->
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-20 h-20 rounded-full bg-gradient-to-br from-[#FF6B35] to-[#C83B08] flex items-center justify-center group-hover:scale-110 group-hover:shadow-[0_4px_24px_rgba(255,107,53,0.5)] transition-all duration-300">
                    <svg class="w-10 h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
                {video.duration && (
                  <div class="absolute bottom-3 right-3 bg-black/70 backdrop-blur-sm text-white px-2.5 py-1 rounded-lg font-montserrat text-xs font-bold">
                    {video.duration}
                  </div>
                )}
              </div>

              <div class="p-6 space-y-2">
                <span class="inline-block px-3 py-1 rounded-full font-montserrat text-xs font-bold text-white bg-gradient-to-r from-[#701D2A] to-[#8C2A3B]">
                  {video.category}
                </span>
                <h3 class="font-montserrat text-xl font-black text-gray-900 dark:text-white group-hover:text-[#FF6B35] transition-colors duration-300">{video.title}</h3>
                <p class="font-quicksand text-gray-600 dark:text-gray-400 text-sm leading-relaxed">{video.description}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="py-24 bg-gray-50 dark:bg-[#130308]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="relative overflow-hidden rounded-3xl">
        <div class="absolute inset-0 bg-gradient-to-br from-[#701D2A] via-[#8C2A3B] to-[#3A0C13]" aria-hidden="true"></div>
        <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-[#FF6B35]/15 blur-[60px] pointer-events-none" aria-hidden="true"></div>
        <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;" aria-hidden="true"></div>

        <div class="relative z-10 px-8 py-14 space-y-6">
          <h2 class="font-montserrat text-3xl lg:text-4xl font-black text-white">
            ¿Querés ser parte de nuestra comunidad?
          </h2>
          <p class="font-quicksand text-xl text-white/80 max-w-xl mx-auto">
            Uníte a Walter Entrenamiento y compartí tus propios momentos de transformación.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <PrimaryButton
              href="https://wa.me/5491168271296?text=Hola,%20me%20gustaría%20agendar%20una%20clase%20de%20prueba"
              text="Reservar Clase de Prueba"
              icon="whatsapp"
              variant="whatsapp"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <PrimaryButton
              href="https://instagram.com/walter.entrenamiento"
              text="Seguir en Instagram"
              icon="instagram"
              variant="secondary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
              class="border-white/80 text-white hover:bg-white hover:text-[#701D2A] dark:border-white/80"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Gallery filtering
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const galleryItems = document.querySelectorAll<HTMLElement>('.gallery-item');
    const emptyState = document.getElementById('empty-state');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter') ?? 'todos';

        // Update active button styling
        filterBtns.forEach(b => {
          b.classList.remove(
            'bg-gradient-to-r', 'from-[#FF6B35]', 'to-[#C83B08]', 'text-white',
            'border-transparent', 'shadow-[0_2px_12px_rgba(255,107,53,0.30)]', 'active'
          );
          b.classList.add(
            'bg-white', 'dark:bg-[#1a0509]', 'text-gray-700', 'dark:text-gray-300',
            'border-gray-200', 'dark:border-white/8'
          );
        });
        btn.classList.remove(
          'bg-white', 'dark:bg-[#1a0509]', 'text-gray-700', 'dark:text-gray-300',
          'border-gray-200', 'dark:border-white/8'
        );
        btn.classList.add(
          'bg-gradient-to-r', 'from-[#FF6B35]', 'to-[#C83B08]', 'text-white',
          'border-transparent', 'shadow-[0_2px_12px_rgba(255,107,53,0.30)]', 'active'
        );

        // Filter items
        let visibleCount = 0;
        galleryItems.forEach(item => {
          const cat = item.getAttribute('data-category') ?? '';
          if (filter === 'todos' || cat === filter) {
            item.style.display = 'block';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        if (emptyState) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
        }
      });
    });
  });
</script>
