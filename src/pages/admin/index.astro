---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAuth } from '../../lib/auth';
import { adminDb } from '../../lib/firebase-admin';

const session = await requireAuth(Astro);
if (session instanceof Response) return session;

let articleCount = 0;
let galleryCount = 0;
let publishedCount = 0;
let draftCount = 0;
let dashboardError = '';

try {
  if (!adminDb) {
    throw new Error('Firebase Admin database is unavailable.');
  }

  [articleCount, galleryCount] = await Promise.all([
    adminDb.collection('articles').count().get().then(s => s.data().count),
    adminDb.collection('gallery_items').count().get().then(s => s.data().count),
  ]);

  [publishedCount, draftCount] = await Promise.all([
    adminDb.collection('articles').where('published', '==', true).count().get().then(s => s.data().count),
    adminDb.collection('articles').where('published', '==', false).count().get().then(s => s.data().count),
  ]);
} catch (error) {
  console.error('[admin] Dashboard metrics failed:', error);
  dashboardError = 'No pudimos cargar las metricas del panel en este entorno.';
}
---

<AdminLayout title="Dashboard" activePage="dashboard">
  <div>
    <h1 style="font-family: 'Montserrat', sans-serif; font-size: 1.5rem; font-weight: 700; color: #f9fafb; margin-bottom: 0.5rem;">
      Dashboard
    </h1>
    <p style="color: #9ca3af; margin-bottom: 2rem; font-size: 0.9rem;">
      Bienvenido, Walter. Desde acá podés gestionar los artículos y la galería del sitio.
    </p>

    {dashboardError && (
      <div style="margin-bottom: 1.5rem; background: #422006; border: 1px solid #d97706; color: #fde68a; border-radius: 0.75rem; padding: 1rem 1.25rem; font-size: 0.9rem;">
        {dashboardError}
      </div>
    )}

    <!-- Stats grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2.5rem;">
      <div style="background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.5rem;">
        <div style="font-size: 2rem; font-weight: 700; font-family: 'Montserrat', sans-serif; color: #FF6B35;">{articleCount ?? 0}</div>
        <div style="color: #9ca3af; font-size: 0.875rem; margin-top: 0.25rem;">Artículos totales</div>
      </div>
      <div style="background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.5rem;">
        <div style="font-size: 2rem; font-weight: 700; font-family: 'Montserrat', sans-serif; color: #34d399;">{publishedCount ?? 0}</div>
        <div style="color: #9ca3af; font-size: 0.875rem; margin-top: 0.25rem;">Publicados</div>
      </div>
      <div style="background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.5rem;">
        <div style="font-size: 2rem; font-weight: 700; font-family: 'Montserrat', sans-serif; color: #fbbf24;">{draftCount ?? 0}</div>
        <div style="color: #9ca3af; font-size: 0.875rem; margin-top: 0.25rem;">Borradores</div>
      </div>
      <div style="background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.5rem;">
        <div style="font-size: 2rem; font-weight: 700; font-family: 'Montserrat', sans-serif; color: #a78bfa;">{galleryCount ?? 0}</div>
        <div style="color: #9ca3af; font-size: 0.875rem; margin-top: 0.25rem;">Items en galería</div>
      </div>
    </div>

    <!-- Quick actions -->
    <h2 style="font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 600; color: #d1d5db; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em;">
      Acciones rápidas
    </h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem;">
      <a
        href="/admin/articulos/nuevo"
        style="display: flex; align-items: center; gap: 1rem; background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.25rem 1.5rem; text-decoration: none; color: #f9fafb; transition: border-color 0.15s;"
      >
        <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #FF6B35, #C83B08); border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
        </div>
        <div>
          <div style="font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.9rem;">Nuevo artículo</div>
          <div style="color: #9ca3af; font-size: 0.8rem; margin-top: 0.1rem;">Bienestar blog</div>
        </div>
      </a>

      <a
        href="/admin/galeria/nuevo"
        style="display: flex; align-items: center; gap: 1rem; background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.25rem 1.5rem; text-decoration: none; color: #f9fafb; transition: border-color 0.15s;"
      >
        <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #a78bfa, #7c3aed); border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
        </div>
        <div>
          <div style="font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.9rem;">Subir foto/video</div>
          <div style="color: #9ca3af; font-size: 0.8rem; margin-top: 0.1rem;">Galería</div>
        </div>
      </a>

      <a
        href="/admin/articulos"
        style="display: flex; align-items: center; gap: 1rem; background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.25rem 1.5rem; text-decoration: none; color: #f9fafb;"
      >
        <div style="width: 40px; height: 40px; background: #374151; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="20" height="20" fill="none" stroke="#d1d5db" stroke-width="2" viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <div>
          <div style="font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.9rem;">Ver artículos</div>
          <div style="color: #9ca3af; font-size: 0.8rem; margin-top: 0.1rem;">Gestionar todos</div>
        </div>
      </a>

      <a
        href="/admin/galeria"
        style="display: flex; align-items: center; gap: 1rem; background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 1.25rem 1.5rem; text-decoration: none; color: #f9fafb;"
      >
        <div style="width: 40px; height: 40px; background: #374151; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="20" height="20" fill="none" stroke="#d1d5db" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
        <div>
          <div style="font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.9rem;">Ver galería</div>
          <div style="color: #9ca3af; font-size: 0.8rem; margin-top: 0.1rem;">Gestionar todos</div>
        </div>
      </a>
    </div>
  </div>
</AdminLayout>
