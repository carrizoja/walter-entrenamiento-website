---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAuth } from '../../../lib/auth';
import { getAllArticles, deleteArticle, toggleArticlePublished } from '../../../lib/queries';

const session = await requireAuth(Astro);
if (session instanceof Response) return session;

// Handle POST actions (delete / toggle published)
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;
  const id = form.get('id') as string;

  if (action === 'delete') {
    await deleteArticle(id);
  } else if (action === 'toggle') {
    const published = form.get('published') === 'true';
    await toggleArticlePublished(id, !published);
  }

  return Astro.redirect('/admin/articulos');
}

const articles = await getAllArticles();

const ARTICLE_CATEGORIES = ['Entrenamiento', 'Consejos', 'Motivación', 'Nutrición', 'Recuperación', 'Salud Mental'];
---

<AdminLayout title="Artículos" activePage="articulos">
  <div>
    <!-- Header -->
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 style="font-family: 'Montserrat', sans-serif; font-size: 1.5rem; font-weight: 700; color: #f9fafb;">Artículos</h1>
        <p style="color: #9ca3af; font-size: 0.875rem; margin-top: 0.25rem;">{articles.length} artículo{articles.length !== 1 ? 's' : ''} en total</p>
      </div>
      <a
        href="/admin/articulos/nuevo"
        style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; background: linear-gradient(135deg, #FF6B35, #C83B08); color: white; border-radius: 0.5rem; font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.875rem; text-decoration: none;"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Nuevo artículo
      </a>
    </div>

    <!-- Table -->
    {articles.length === 0 ? (
      <div style="background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; padding: 3rem; text-align: center;">
        <p style="color: #9ca3af;">Todavía no hay artículos. <a href="/admin/articulos/nuevo" style="color: #FF6B35;">Creá el primero.</a></p>
      </div>
    ) : (
      <div style="background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 1px solid #374151;">
              <th style="padding: 0.875rem 1.25rem; text-align: left; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em;">Título</th>
              <th style="padding: 0.875rem 1rem; text-align: left; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;">Categoría</th>
              <th style="padding: 0.875rem 1rem; text-align: left; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em;">Estado</th>
              <th style="padding: 0.875rem 1rem; text-align: left; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;">Destacado</th>
              <th style="padding: 0.875rem 1.25rem; text-align: right; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {articles.map((article) => (
              <tr style="border-bottom: 1px solid #374151;">
                <td style="padding: 1rem 1.25rem;">
                  <div style="font-weight: 600; color: #f9fafb; font-size: 0.9rem; margin-bottom: 0.2rem;">{article.title}</div>
                  <div style="color: #6b7280; font-size: 0.775rem;">{article.slug}</div>
                </td>
                <td style="padding: 1rem;">
                  <span style="background: #374151; color: #d1d5db; padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.775rem; white-space: nowrap;">
                    {article.category}
                  </span>
                </td>
                <td style="padding: 1rem;">
                  <form method="POST" style="display: inline;">
                    <input type="hidden" name="_action" value="toggle" />
                    <input type="hidden" name="id" value={article.id} />
                    <input type="hidden" name="published" value={String(article.published)} />
                    <button
                      type="submit"
                      style={`padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.775rem; border: none; cursor: pointer; white-space: nowrap; font-family: 'Quicksand', sans-serif; font-weight: 600; ${article.published ? 'background: #064e3b; color: #34d399;' : 'background: #451a03; color: #fbbf24;'}`}
                    >
                      {article.published ? 'Publicado' : 'Borrador'}
                    </button>
                  </form>
                </td>
                <td style="padding: 1rem; text-align: center;">
                  {article.featured ? (
                    <span style="color: #FF6B35;">★</span>
                  ) : (
                    <span style="color: #4b5563;">—</span>
                  )}
                </td>
                <td style="padding: 1rem 1.25rem;">
                  <div style="display: flex; align-items: center; gap: 0.5rem; justify-content: flex-end;">
                    <a
                      href={`/admin/articulos/${article.id}`}
                      style="padding: 0.375rem 0.75rem; background: #374151; color: #d1d5db; border-radius: 0.375rem; font-size: 0.8rem; text-decoration: none; font-family: 'Montserrat', sans-serif; font-weight: 500; white-space: nowrap;"
                    >
                      Editar
                    </a>
                    <form method="POST" onsubmit="return confirm('¿Seguro que querés eliminar este artículo?')">
                      <input type="hidden" name="_action" value="delete" />
                      <input type="hidden" name="id" value={article.id} />
                      <button
                        type="submit"
                        style="padding: 0.375rem 0.75rem; background: #450a0a; color: #fca5a5; border: none; border-radius: 0.375rem; font-size: 0.8rem; cursor: pointer; font-family: 'Montserrat', sans-serif; font-weight: 500; white-space: nowrap;"
                      >
                        Eliminar
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>
